# ============================================================
#  PORTFOLIO SERVER — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ============================================================

# ── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api

# ── PostgreSQL Database (Prisma) ───────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Example (Cloud):   postgresql://postgres:pass@your-cloud-host.com:5432/portfolio?sslmode=require
# Example (Local):   postgresql://postgres:password@localhost:5432/portfolio
DATABASE_URL=postgresql://postgres:pass@your-cloud-host.com:5432/portfolio?sslmode=require

# ── JWT Authentication ──────────────────────────────────────
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YourScerect
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
#CORS_ORIGIN=https://nishanth.qzz.io

# ── File Uploads ────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=50
UPLOAD_PUBLIC_URL=https://nishanth.qzz.io/uploads

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Blog View Tracking ──────────────────────────────────────
VIEW_COOKIE_MAX_AGE_HOURS=24

# ── Temp File Share ─────────────────────────────────────────
SHARE_MAX_EXPIRY_HOURS=168

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── Admin Seed Credentials ──────────────────────────────────
ADMIN_USERNAME=np
ADMIN_PASSWORD=Password
ADMIN_EMAIL=np@[EMAIL_ADDRESS]

# ── G-Mail STMP ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[EMAIL_ADDRESS]
SMTP_PASS=Key
SMTP_FROM=nishanthpechimuthu@gmail.com
EMAIL_NAME=Nishanth P

# ── Resend API ─────────────────────────
RESEND_NAME=Nishanth P
RESEND_EMAIL=nishanth@nishanth.qzz.io
RESEND_KEY=RESEND_KEY

# ── Resend API ─────────────────────────
REPLY_EMAIL=contact@nishanth.qzz.io