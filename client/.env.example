# ============================================================
#  PORTFOLIO CLIENT — Environment Variables
#  Copy this file to .env.local and fill in your values
#  Vite exposes only variables prefixed with VITE_ to the browser
# ============================================================

# ── API Backend URL ─────────────────────────────────────────
# Local development
VITE_API_URL=http://localhost:3001/api
# Production example:
# VITE_API_URL=https://api.yourportfolio.com/api

# ── Public Site URL ─────────────────────────────────────────
VITE_SITE_URL=http://localhost:5173
# Production:
# VITE_SITE_URL=https://yourportfolio.com

# ── App Name ────────────────────────────────────────────────
VITE_APP_NAME=Nishanth Portfolio
VITE_APP_VERSION=2.0.0
